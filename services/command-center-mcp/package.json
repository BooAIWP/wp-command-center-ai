{
  "name": "@wp-command-center-ai/mcp-server",
  "version": "0.1.0",
  "private": true,
  "description": "External MCP control plane for WP Command Center AI OS.",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "check": "npm run typecheck && npm test && npm run build",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/src/index.js",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "express": "^5.1.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
