{
  "name": "wp-command-center-ai/project",
  "description": "Monorepo for the WP Command Center AI Master and Client plugins.",
  "type": "project",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=8.1"
  },
  "require-dev": {
    "phpcompatibility/php-compatibility": "^9.3",
    "phpunit/phpunit": "^10.5",
    "squizlabs/php_codesniffer": "^3.10",
    "wp-coding-standards/wpcs": "^3.1"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    },
    "optimize-autoloader": true,
    "sort-packages": true
  },
  "autoload": {
    "psr-4": {
      "WPCommandCenterAI\\Master\\": "plugins/wp-command-center-ai-master/src/",
      "WPCommandCenterAI\\Client\\": "plugins/wp-command-center-ai-client/src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "WPCommandCenterAI\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "check": [
      "@lint",
      "@test"
    ],
    "lint": "phpcs",
    "lint:fix": "phpcbf",
    "test": "phpunit"
  }
}
